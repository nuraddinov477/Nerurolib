{
  "name": "neurolib",
  "version": "1.0.0",
  "description": "Book store web application with admin panel",
  "private": true,
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^5.4.624",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^6.20.0"
  },
  "scripts": {
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "start": "NODE_ENV=production node server.js",
    "server:node": "PORT=3001 node server.js",
    "server:dev": "PORT=3001 nodemon server.js",
    "all": "concurrently -n \"React,Node\" -c \"cyan,green\" \"npm run dev\" \"npm run server:node\"",
    "build:deploy": "npm run build && NODE_ENV=production node server.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:8000",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "react-scripts": "5.0.1"
  }
}
